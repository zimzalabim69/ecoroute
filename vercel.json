{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "_comment": "EcoRoute Vercel Configuration (BONES ONLY). Activate by deploying with: vercel --prod",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob:; connect-src 'self' https:; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests;" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/stripe/webhook",
      "destination": "/api/stripe-webhook"
    }
  ],
  "env": {
    "_comment_env": "These are FALLBACKS. Real values are set via 'vercel env add' or Vercel Dashboard.",
    "NEXT_PUBLIC_SUPABASE_URL": "@ecoroute-supabase-url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@ecoroute-supabase-anon",
    "SUPABASE_SERVICE_ROLE_KEY": "@ecoroute-supabase-service"
  }
}
